NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — local dev instant signup (auto-confirms email, skips verification).
# Supabase Dashboard → Project Settings → API → service_role (never expose to the browser).
# Ignored in production unless AUTH_INSTANT_SIGNUP=true (do not set in production).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: force instant signup outside development (local testing only).
# AUTH_INSTANT_SIGNUP=true
